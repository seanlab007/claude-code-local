# ============================================================
# Claude Code Local Proxy — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ─── Proxy Server ────────────────────────────────────────────
PROXY_HOST=0.0.0.0
PROXY_PORT=8082

# ─── Backend Provider ────────────────────────────────────────
# Options: anthropic | openai | openclaw | workbuddy
# - anthropic : Direct Anthropic API (requires ANTHROPIC_API_KEY)
# - openai    : OpenAI or any OpenAI-compatible API (Ollama, LM Studio)
# - openclaw  : Route through your local OpenClaw gateway (port 18789)
# - workbuddy : Route through Tencent WorkBuddy (port 18789, OpenClaw-compatible)
PREFERRED_PROVIDER=anthropic

# ─── Anthropic API ───────────────────────────────────────────
# Required when PREFERRED_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── OpenAI / Compatible API ─────────────────────────────────
# Required when PREFERRED_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key

# For local models (Ollama, LM Studio, etc.)
# OPENAI_BASE_URL=http://localhost:11434/v1   # Ollama
# OPENAI_BASE_URL=http://localhost:1234/v1    # LM Studio

# ─── Model Mapping ───────────────────────────────────────────
# Claude "sonnet" requests map to BIG_MODEL
# Claude "haiku" requests map to SMALL_MODEL
BIG_MODEL=claude-sonnet-4-5
SMALL_MODEL=claude-haiku-4-5

# For OpenAI provider:
# BIG_MODEL=gpt-4.1
# SMALL_MODEL=gpt-4.1-mini

# For local Ollama models:
# BIG_MODEL=qwen2.5-coder:32b
# SMALL_MODEL=qwen2.5-coder:7b

# ─── OpenClaw Integration ────────────────────────────────────
# Required when PREFERRED_PROVIDER=openclaw
# Official API: POST http://127.0.0.1:18789/v1/chat/completions
# Auth: Authorization: Bearer <OPENCLAW_GATEWAY_TOKEN>
# Model format: "openclaw:main" or "openclaw:<agentId>"
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your-openclaw-gateway-token
OPENCLAW_AGENT_ID=main

# ─── WorkBuddy Integration ───────────────────────────────────
# Required when PREFERRED_PROVIDER=workbuddy
# WorkBuddy (Tencent) is fully compatible with OpenClaw API:
#   - Same port: 18789 (default)
#   - Same auth: Authorization: Bearer <token>
#   - Same model format: "openclaw:main"
#
# How to get WorkBuddy Gateway Token:
#   1. Open WorkBuddy app on your computer
#   2. Go to Settings → API → Generate Gateway Token
#   3. Copy the token and paste below
#
WORKBUDDY_BASE_URL=http://127.0.0.1:18789
WORKBUDDY_GATEWAY_TOKEN=your-workbuddy-gateway-token
WORKBUDDY_AGENT_ID=main
