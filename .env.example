# ============================================================
# Claude Code Local Proxy — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ─── Proxy Server ────────────────────────────────────────────
PROXY_HOST=0.0.0.0
PROXY_PORT=8082

# ─── Backend Provider ────────────────────────────────────────
# Options: anthropic | openai | openclaw | workbuddy
# - anthropic: Direct Anthropic API (requires ANTHROPIC_API_KEY)
# - openai: OpenAI or any OpenAI-compatible API (Ollama, LM Studio)
# - openclaw: Route through your OpenClaw gateway
# - workbuddy: Route through your WorkBuddy service
PREFERRED_PROVIDER=anthropic

# ─── Anthropic API ───────────────────────────────────────────
# Required when PREFERRED_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── OpenAI / Compatible API ─────────────────────────────────
# Required when PREFERRED_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key

# For local models (Ollama, LM Studio, etc.)
# OPENAI_BASE_URL=http://localhost:11434/v1   # Ollama
# OPENAI_BASE_URL=http://localhost:1234/v1    # LM Studio

# ─── Model Mapping ───────────────────────────────────────────
# Claude "sonnet" requests map to BIG_MODEL
# Claude "haiku" requests map to SMALL_MODEL
BIG_MODEL=claude-sonnet-4-5
SMALL_MODEL=claude-haiku-4-5

# For OpenAI provider:
# BIG_MODEL=gpt-4.1
# SMALL_MODEL=gpt-4.1-mini

# For local Ollama models:
# BIG_MODEL=qwen2.5-coder:32b
# SMALL_MODEL=qwen2.5-coder:7b

# ─── OpenClaw Integration ────────────────────────────────────
# Required when PREFERRED_PROVIDER=openclaw
# Also used for webhook integration regardless of provider
OPENCLAW_BASE_URL=http://localhost:3000
OPENCLAW_GATEWAY_TOKEN=your-openclaw-gateway-token

# ─── WorkBuddy Integration ───────────────────────────────────
# Required when PREFERRED_PROVIDER=workbuddy
WORKBUDDY_BASE_URL=http://localhost:4000
WORKBUDDY_API_KEY=your-workbuddy-api-key
